# ─────────────────────────────────────────────────────────────────────────────
# SmartShop Backend — Environment Variables
# Copy this file to .env and fill in the values before starting the server.
# NEVER commit the .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB connection string (local or Atlas)
MONGODB_URI=mongodb://localhost:27017/smartshop

# ── Authentication ────────────────────────────────────────────────────────────
# Strong random secret for signing JWTs (min 32 chars recommended)
JWT_SECRET=your_jwt_secret_here
# Token expiry duration (e.g. 24h, 7d)
JWT_EXPIRE=24h
# bcrypt salt rounds (10 is a good default; higher = slower but more secure)
BCRYPT_ROUNDS=10

# ── Stripe (international payments — USD) ─────────────────────────────────────
# Optional — leave blank to disable card payments until you're ready
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Chapa (Ethiopian payments — ETB) ─────────────────────────────────────────
# Optional — leave blank to disable local payments until you're ready
CHAPA_SECRET_KEY=
CHAPA_WEBHOOK_SECRET=

# ── Cloud Storage / Cloudinary ────────────────────────────────────────────────
# Optional — leave blank to disable image uploads until you're ready
CLOUD_STORAGE_KEY=
CLOUD_STORAGE_BUCKET=
CLOUDINARY_CLOUD_NAME=

# ── Email Service ─────────────────────────────────────────────────────────────
# Option 1 — Gmail (easiest): set EMAIL_USER + EMAIL_PASS (use a Gmail App Password)
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_gmail_app_password

# Option 2 — SendGrid: set EMAIL_SERVICE_API_KEY
EMAIL_SERVICE_API_KEY=

# Option 3 — Generic SMTP (AWS SES, Mailgun, etc.)
# EMAIL_HOST=email-smtp.us-east-1.amazonaws.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=your_smtp_user
# EMAIL_PASS=your_smtp_pass

# Sender address shown in emails
SENDGRID_FROM_EMAIL=your@gmail.com

# ── Exchange Rate API ─────────────────────────────────────────────────────────
# Optional — falls back to a hardcoded rate (56.5 ETB/USD) if not set
EXCHANGE_RATE_API_KEY=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
